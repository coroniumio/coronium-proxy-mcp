# Coronium MCP Server Configuration
# Copy this file to .env and fill in your credentials.

# ---- Required (or call coronium_login manually each session) ----
CORONIUM_LOGIN=your-email@example.com
CORONIUM_PASSWORD=your-password

# ---- Optional ----

# Override API base URL. The canonical production API is /api/v3 — the
# OpenAPI spec at https://dashboard.coronium.io/api-docs/ lists exactly
# one server URL, and that's it.
# CORONIUM_BASE_URL=https://api.coronium.io/api/v3

# Token-based rotation endpoint (used by coronium_rotate_modem).
# CORONIUM_ROTATION_URL=https://mreset.xyz

# Live coin price source for crypto-balance USD valuation.
# CORONIUM_PRICES_URL=https://api.coingecko.com/api/v3/simple/price

# Disable transparent token refresh on 401 (default ON when login+password set).
# CORONIUM_AUTO_LOGIN=0

# Pin the at-rest token encryption key. Defaults to a per-process random
# value — auto-login re-mints tokens transparently if cache is lost, so
# pinning is only worthwhile if you want survive-restart token caching.
# TOKEN_ENCRYPTION_KEY=64-hex-chars

# Logging: error | warn | info | debug
LOG_LEVEL=info
